# Editor configuration, see https://editorconfig.org
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,json,cjs,mjs}]
indent_style = space
indent_size = 2

[*.{py}]
indent_style = space
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 2
