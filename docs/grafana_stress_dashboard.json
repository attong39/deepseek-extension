{
  "dashboard": {
    "title": "Ollama Stress Test Results",
    "panels": [
      {
        "title": "Requests per Second",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(zeta_ollama_requests_total[5m]))",
            "legendFormat": "RPS"
          }
        ]
      },
      {
        "title": "P95 Latency",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(zeta_ollama_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95 Latency"
          }
        ]
      }
    ]
  }
}
