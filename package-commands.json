    "menus": {
      "commandPalette": [
        {
          "command": "deepseek.aiAgent.interactive",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.reviewActiveFile",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.debugActiveFile",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.optimizeActiveFile",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.testActiveFile",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.documentActiveFile",
          "when": "editorTextFocus"
        }
      ],
      "editor/context": [
        {
          "command": "deepseek.aiAgent.reviewActiveFile",
          "group": "deepseek@1",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.optimizeActiveFile",
          "group": "deepseek@2",
          "when": "editorTextFocus"
        },
        {
          "command": "deepseek.aiAgent.debugActiveFile",
          "group": "deepseek@3",
          "when": "editorTextFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "deepseek.aiAgent.interactive",
        "key": "ctrl+shift+d ctrl+shift+i",
        "when": "editorTextFocus"
      },
      {
        "command": "deepseek.aiAgent.reviewActiveFile",
        "key": "ctrl+shift+d ctrl+shift+r",
        "when": "editorTextFocus"
      },
      {
        "command": "deepseek.aiAgent.optimizeActiveFile",
        "key": "ctrl+shift+d ctrl+shift+o",
        "when": "editorTextFocus"
      }
    ]
  }
}