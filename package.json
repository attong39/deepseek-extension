{
  "name": "deekseek-extension",
  "displayName": "DeepSeek extension",
  "description": "DeepSeek AI assistant with Python development workflow integration, code review, and debugging support",
  "version": "1.0.1",
  "publisher": "aryansrao",
  "author": {
    "name": "aryansrao"
  },
  "icon": "media/deepseek.png",
  "galleryBanner": {
    "color": "#2C2C32",
    "theme": "dark"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryansrao/deepseek-extension.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages",
    "Education",
    "Other"
  ],
  "keywords": [
    "ai",
    "deepseek",
    "ollama",
    "chat",
    "code-assistant",
    "code-completion",
    "local-ai",
    "python",
    "python-development",
    "code-review",
    "debugging",
    "testing",
    "documentation"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deep-seek.start",
        "title": "Start DeepSeek Chat"
      },
      {
        "command": "deep-seek.python.start",
        "title": "Start Python Assistant"
      },
      {
        "command": "deep-seek.python.review",
        "title": "Review Python Code"
      },
      {
        "command": "deep-seek.python.debug",
        "title": "Debug Python Code"
      },
      {
        "command": "deep-seek.python.optimize",
        "title": "Optimize Python Code"
      },
      {
        "command": "deep-seek.python.document",
        "title": "Generate Python Documentation"
      },
      {
        "command": "deep-seek.python.test",
        "title": "Generate Python Tests"
      },
      {
        "command": "deepseek.agent.runTask",
        "title": "DeepSeek: Run AI Agent Task"
      },
      {
        "command": "deepseek.agent.reviewActiveFile",
        "title": "DeepSeek: Review Current File"
      },
      {
        "command": "deepseek.agent.continuous",
        "title": "DeepSeek: Continuous Optimize (Light)"
      }
    ],
    "configuration": {
      "title": "DeepSeek",
      "properties": {
        "deepseek.ollamaUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama service URL"
        },
        "deepseek.ollamaModel": {
          "type": "string",
          "default": "deepseek-r1:latest",
          "description": "Default Ollama model to use"
        },
        "deepseek.ollamaTimeout": {
          "type": "number",
          "default": 15000,
          "description": "Timeout for Ollama requests in milliseconds"
        },
        "deepseek.temperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1,
          "description": "Temperature for model responses (0-1)"
        },
        "deepseek.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Apply plan without confirmation"
        },
        "deepseek.maxContextBytes": {
          "type": "number",
          "default": 40000,
          "description": "Maximum context size in bytes"
        },
        "deepseek.promptTemplateFolder": {
          "type": "string",
          "default": "~/.deepseek/templates",
          "description": "Folder containing custom prompt templates"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "ollama": "^0.5.12"
  }
}
