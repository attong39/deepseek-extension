{
  "$id": "https://zeta.ai/schemas/plugin-manifest.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9.]+)?$"
    },
    "description": {
      "type": "string"
    },
    "entry": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "system-info",
          "ui-widget",
          "websocket-listener",
          "training",
          "monitor"
        ]
      },
      "default": []
    }
  },
  "required": [
    "key",
    "name",
    "version",
    "entry"
  ]
}