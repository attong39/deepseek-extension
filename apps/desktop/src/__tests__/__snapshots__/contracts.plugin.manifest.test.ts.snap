exports[`Plugin manifest schema freeze > is stable 1`] = `
{
  "$id": "https://zeta.ai/schemas/plugin-manifest.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "default": [],
      "items": {
        "enum": [
          "system-info",
          "ui-widget",
          "websocket-listener",
          "training",
          "monitor",
        ],
        "type": "string",
      },
      "type": "array",
    },
    "description": {
      "type": "string",
    },
    "enabled": {
      "default": false,
      "type": "boolean",
    },
    "entry": {
      "type": "string",
    },
    "key": {
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$",
      "type": "string",
    },
    "name": {
      "minLength": 1,
      "type": "string",
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9.]+)?$",
      "type": "string",
    },
  },
  "required": [
    "key",
    "name",
    "version",
    "entry",
  ],
  "title": "Plugin Manifest",
  "type": "object",
}
